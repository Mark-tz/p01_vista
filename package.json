{
  "name": "vista-docs",
  "version": "0.1.0",
  "private": true,
  "description": "VISTA 智能巡检调度系统 — 文档工具",
  "type": "module",
  "scripts": {
    "docs:pdf": "node scripts/export-docs.mjs",
    "docs:pdf:all": "node scripts/export-docs.mjs --combined",
    "docs:pdf:help": "node scripts/export-docs.mjs --help",
    "docs:serve": "mkdocs serve -a 0.0.0.0:8000",
    "docs:build": "mkdocs build",
    "docs:deploy": "mkdocs gh-deploy --force"
  },
  "devDependencies": {
    "md-to-pdf": "^5.2.5"
  }
}
